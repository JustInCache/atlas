# Atlas Production Environment Variables
# Copy to .env and customize for your AWS EKS deployment

# ============================================
# Application Configuration
# ============================================
CONFIG_PATH=/app/config.yaml
PORT=8080

# ============================================
# Cache Configuration (Redis)
# ============================================
CACHE_TYPE=redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=your-secure-redis-password-here
REDIS_DB=0

# ============================================
# Multi-Cluster Mode
# ============================================
MULTI_CLUSTER=true

# ============================================
# AWS EKS Configuration
# ============================================
# AWS Region (override for specific environments)
AWS_REGION=us-east-1

# AWS Credentials (if not using IAM roles)
# Recommended: Use IAM roles for EKS cluster access instead
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=your-session-token-if-using-sts

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# Security
# ============================================
# Enable HTTPS (if using reverse proxy)
# ENABLE_TLS=true
# TLS_CERT_PATH=/app/certs/tls.crt
# TLS_KEY_PATH=/app/certs/tls.key

# ============================================
# Performance Tuning
# ============================================
# Go runtime
GOMAXPROCS=4
GOMEMLIMIT=1GiB

# ============================================
# Notes
# ============================================
# 1. For production, use AWS Secrets Manager or Parameter Store for sensitive values
# 2. Use IAM roles for service accounts (IRSA) when running on EKS
# 3. Never commit .env file with real credentials to version control
# 4. Rotate REDIS_PASSWORD regularly
# 5. Consider using AWS Systems Manager Parameter Store for configuration