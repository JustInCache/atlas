# Atlas Environment Variables
# Copy to .env and customize for your deployment

# ============================================
# Cache Configuration
# ============================================
CACHE_TYPE=memory                    # Options: memory, redis
REDIS_ADDR=localhost:6379           # Redis server address (only if CACHE_TYPE=redis)
REDIS_PASSWORD=                     # Redis password (optional)
REDIS_DB=0                          # Redis database number

# ============================================
# Cluster Configuration
# ============================================
CLUSTER_ID=default                  # Current cluster ID (used for Redis namespacing)
CLUSTER_NAME=Default Cluster        # Display name for the cluster
CLUSTER_REGION=                     # Optional region identifier

# ============================================
# Multi-Cluster Mode
# ============================================
MULTI_CLUSTER=false                 # Enable multi-cluster support (true/false)
# KUBECONFIG=/path/to/kubeconfig    # Path to kubeconfig file (optional)

# ============================================
# Server Configuration
# ============================================
PORT=8080                           # HTTP server port

# ============================================
# Logging
# ============================================
LOG_LEVEL=info                      # Options: debug, info, warn, error
